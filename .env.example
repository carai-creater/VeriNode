# === セキュリティ ===
# 本番（例: Vercel）: このファイルは使わない。ダッシュボードの Environment Variables に同じ名前で設定する。
# Vercel では VERCEL=1 のためアプリは .env を読みません（誤ってデプロイに含めても読み込まれない）。
# ローカル: このファイルをコピーして .env を作る。.env は .gitignore 済み — 絶対にコミットしない。
#
# ローカルで .env すら使いたくない場合: export SERPER_API_KEY=... のようにシェルで渡すか DISABLE_DOTENV=1

# Search (use Serper OR Google Custom Search)
SERPER_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Payment gate (402 + X-Payment-Link)
# ローカルでは 1 推奨。本番で課金を有効: VERIFY_SKIP_PAYMENT=0
VERIFY_SKIP_PAYMENT=1

# --- 課金 A: Stripe Checkout（推奨）---
# STRIPE_SECRET_KEY を入れたら「Stripe モード」。このとき PUBLIC_BASE_URL（ローカル必須）または
# VERCEL_URL / RENDER_EXTERNAL_URL / RAILWAY_PUBLIC_DOMAIN のいずれかが必須。無いと 503 になり example.com には落ちない。
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 固定 Price を使う場合（推奨）。未設定なら JPY の都度 amount（STRIPE_VERIFY_UNIT_AMOUNT_JPY）で動的生成。
STRIPE_PRICE_ID=
STRIPE_VERIFY_UNIT_AMOUNT_JPY=100
# ローカル + 課金テスト: 必ず uvicorn のポートと一致（例: http://127.0.0.1:8000）。本番は https://あなたのドメイン
PUBLIC_BASE_URL=

# --- 課金 B: 固定トークン（Stripe を使わないときのみ）---
# Stripe を使う場合は VERIFY_PAYMENT_TOKEN を空のまま（または行削除）。値があると「トークン方式」が使われる。
PAYMENT_LINK_URL=https://example.com/checkout?product=verinode
VERIFY_PAYMENT_TOKEN=

# Optional: threshold for verified vs unverified (0.0–1.0)
VERIFY_SCORE_THRESHOLD=0.62

# Optional: ブラウザから別オリジンで API を叩く場合（カンマ区切り）。402 の X-Payment-Link を fetch で読むのに必要
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://あなたのフロントドメイン
CORS_ALLOW_ORIGINS=
